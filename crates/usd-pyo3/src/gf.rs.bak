//! pxr.Gf — Graphics Foundation bindings (Vec, Matrix, Quat, etc.)

use pyo3::prelude::*;

// -- Vec3f/Vec3d --

#[pyclass(name = "Vec3f", module = "pxr.Gf")]
#[derive(Clone)]
pub struct PyVec3f(pub glam::Vec3);

#[pymethods]
impl PyVec3f {
    #[new]
    #[pyo3(signature = (x=0.0, y=0.0, z=0.0))]
    fn new(x: f32, y: f32, z: f32) -> Self {
        Self(glam::Vec3::new(x, y, z))
    }

    fn __repr__(&self) -> String {
        format!("Gf.Vec3f({}, {}, {})", self.0.x, self.0.y, self.0.z)
    }

    fn __str__(&self) -> String {
        format!("({}, {}, {})", self.0.x, self.0.y, self.0.z)
    }

    fn __eq__(&self, other: &Self) -> bool { self.0 == other.0 }
    fn __ne__(&self, other: &Self) -> bool { self.0 != other.0 }
    fn __len__(&self) -> usize { 3 }
    fn __hash__(&self) -> u64 {
        use std::hash::{Hash, Hasher};
        let mut h = std::collections::hash_map::DefaultHasher::new();
        self.0.x.to_bits().hash(&mut h);
        self.0.y.to_bits().hash(&mut h);
        self.0.z.to_bits().hash(&mut h);
        h.finish()
    }

    fn __getitem__(&self, i: isize) -> PyResult<f32> {
        match norm_idx(i, 3)? {
            0 => Ok(self.0.x),
            1 => Ok(self.0.y),
            2 => Ok(self.0.z),
            _ => unreachable!(),
        }
    }

    fn __setitem__(&mut self, i: isize, v: f32) -> PyResult<()> {
        match norm_idx(i, 3)? {
            0 => self.0.x = v,
            1 => self.0.y = v,
            2 => self.0.z = v,
            _ => unreachable!(),
        }
        Ok(())
    }

    fn __add__(&self, other: &Self) -> Self { Self(self.0 + other.0) }
    fn __sub__(&self, other: &Self) -> Self { Self(self.0 - other.0) }
    fn __mul__(&self, scalar: f32) -> Self { Self(self.0 * scalar) }
    fn __rmul__(&self, scalar: f32) -> Self { Self(self.0 * scalar) }
    fn __truediv__(&self, scalar: f32) -> PyResult<Self> {
        if scalar == 0.0 { return Err(pyo3::exceptions::PyZeroDivisionError::new_err("division by zero")); }
        Ok(Self(self.0 / scalar))
    }
    fn __neg__(&self) -> Self { Self(-self.0) }

    #[staticmethod]
    #[pyo3(name = "XAxis")]
    fn x_axis() -> Self { Self(glam::Vec3::X) }
    #[staticmethod]
    #[pyo3(name = "YAxis")]
    fn y_axis() -> Self { Self(glam::Vec3::Y) }
    #[staticmethod]
    #[pyo3(name = "ZAxis")]
    fn z_axis() -> Self { Self(glam::Vec3::Z) }

    #[pyo3(name = "GetLength")]
    fn get_length(&self) -> f32 { self.0.length() }
    #[pyo3(name = "GetNormalized")]
    fn get_normalized(&self) -> Self { Self(self.0.normalize_or_zero()) }
    #[pyo3(name = "Normalize")]
    fn normalize(&mut self) -> f32 {
        let len = self.0.length();
        if len > 0.0 { self.0 /= len; }
        len
    }
    #[pyo3(name = "GetDot")]
    fn get_dot(&self, other: &Self) -> f32 { self.0.dot(other.0) }
    #[pyo3(name = "GetCross")]
    fn get_cross(&self, other: &Self) -> Self { Self(self.0.cross(other.0)) }
    #[pyo3(name = "GetProjection")]
    fn get_projection(&self, other: &Self) -> Self {
        let d = other.0.dot(other.0);
        if d == 0.0 { return Self(glam::Vec3::ZERO); }
        Self(other.0 * (self.0.dot(other.0) / d))
    }
    #[pyo3(name = "GetComplement")]
    fn get_complement(&self, other: &Self) -> Self {
        Self(self.0 - self.get_projection(other).0)
    }

    #[getter]
    fn dimension(&self) -> usize { 3 }
}

#[pyclass(name = "Vec3d", module = "pxr.Gf")]
#[derive(Clone)]
pub struct PyVec3d(pub glam::DVec3);

#[pymethods]
impl PyVec3d {
    #[new]
    #[pyo3(signature = (x=0.0, y=0.0, z=0.0))]
    fn new(x: f64, y: f64, z: f64) -> Self { Self(glam::DVec3::new(x, y, z)) }

    fn __repr__(&self) -> String { format!("Gf.Vec3d({}, {}, {})", self.0.x, self.0.y, self.0.z) }
    fn __str__(&self) -> String { format!("({}, {}, {})", self.0.x, self.0.y, self.0.z) }
    fn __eq__(&self, other: &Self) -> bool { self.0 == other.0 }
    fn __ne__(&self, other: &Self) -> bool { self.0 != other.0 }
    fn __len__(&self) -> usize { 3 }
    fn __getitem__(&self, i: isize) -> PyResult<f64> {
        match norm_idx(i, 3)? { 0 => Ok(self.0.x), 1 => Ok(self.0.y), 2 => Ok(self.0.z), _ => unreachable!() }
    }
    fn __setitem__(&mut self, i: isize, v: f64) -> PyResult<()> {
        match norm_idx(i, 3)? { 0 => self.0.x = v, 1 => self.0.y = v, 2 => self.0.z = v, _ => unreachable!() }
        Ok(())
    }
    fn __add__(&self, other: &Self) -> Self { Self(self.0 + other.0) }
    fn __sub__(&self, other: &Self) -> Self { Self(self.0 - other.0) }
    fn __mul__(&self, scalar: f64) -> Self { Self(self.0 * scalar) }
    fn __rmul__(&self, scalar: f64) -> Self { Self(self.0 * scalar) }
    fn __truediv__(&self, scalar: f64) -> PyResult<Self> {
        if scalar == 0.0 { return Err(pyo3::exceptions::PyZeroDivisionError::new_err("division by zero")); }
        Ok(Self(self.0 / scalar))
    }
    fn __neg__(&self) -> Self { Self(-self.0) }

    #[staticmethod]
    #[pyo3(name = "XAxis")]
    fn x_axis() -> Self { Self(glam::DVec3::X) }
    #[staticmethod]
    #[pyo3(name = "YAxis")]
    fn y_axis() -> Self { Self(glam::DVec3::Y) }
    #[staticmethod]
    #[pyo3(name = "ZAxis")]
    fn z_axis() -> Self { Self(glam::DVec3::Z) }

    #[pyo3(name = "GetLength")]
    fn get_length(&self) -> f64 { self.0.length() }
    #[pyo3(name = "GetNormalized")]
    fn get_normalized(&self) -> Self { Self(self.0.normalize_or_zero()) }
    #[pyo3(name = "Normalize")]
    fn normalize(&mut self) -> f64 { let l = self.0.length(); if l > 0.0 { self.0 /= l; } l }
    #[pyo3(name = "GetDot")]
    fn get_dot(&self, other: &Self) -> f64 { self.0.dot(other.0) }
    #[pyo3(name = "GetCross")]
    fn get_cross(&self, other: &Self) -> Self { Self(self.0.cross(other.0)) }

    #[getter]
    fn dimension(&self) -> usize { 3 }
}

// -- Matrix4d --

#[pyclass(name = "Matrix4d", module = "pxr.Gf")]
#[derive(Clone)]
pub struct PyMatrix4d(pub glam::DMat4);

#[pymethods]
impl PyMatrix4d {
    #[new]
    fn new() -> Self { Self(glam::DMat4::IDENTITY) }

    fn __repr__(&self) -> String { format!("Gf.Matrix4d(...)") }
    fn __eq__(&self, other: &Self) -> bool { self.0 == other.0 }
    fn __ne__(&self, other: &Self) -> bool { self.0 != other.0 }

    #[staticmethod]
    #[pyo3(name = "SetIdentity")]
    fn identity() -> Self { Self(glam::DMat4::IDENTITY) }

    #[pyo3(name = "GetInverse")]
    fn get_inverse(&self) -> Self { Self(self.0.inverse()) }
    #[pyo3(name = "GetTranspose")]
    fn get_transpose(&self) -> Self { Self(self.0.transpose()) }
    #[pyo3(name = "GetDeterminant")]
    fn get_determinant(&self) -> f64 { self.0.determinant() }

    #[pyo3(name = "ExtractTranslation")]
    fn extract_translation(&self) -> PyVec3d {
        let col = self.0.col(3);
        PyVec3d(glam::DVec3::new(col.x, col.y, col.z))
    }
}

// -- Helpers --

fn norm_idx(i: isize, len: usize) -> PyResult<usize> {
    let idx = if i < 0 { len as isize + i } else { i };
    if idx < 0 || idx >= len as isize {
        Err(pyo3::exceptions::PyIndexError::new_err("index out of range"))
    } else {
        Ok(idx as usize)
    }
}

/// Register Gf submodule classes.
pub fn register(_py: Python<'_>, m: &Bound<'_, PyModule>) -> PyResult<()> {
    m.add_class::<PyVec3f>()?;
    m.add_class::<PyVec3d>()?;
    m.add_class::<PyMatrix4d>()?;
    Ok(())
}
