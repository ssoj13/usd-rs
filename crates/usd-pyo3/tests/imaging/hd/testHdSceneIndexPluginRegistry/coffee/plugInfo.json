{
    "Plugins": [
        {
            # Using type "resource" instead of "library" to avoid dynamic 
            # library loading in the test environment.
            # testHdSceneIndexPluginRegistry.cpp defines all of the plugins
            # below.
            "Type": "resource",
            "Name": "coffeePlugins",
            
            "Info": {
                "Types": {
                    "TestHdSip_GrindBeans" : {
                        "bases": ["HdSceneIndexPlugin"],
                        "loadWithRenderer" : "",
                        "loadWithApps" : "",

                        # New fields to express scene index plugin ordering
                        # via JSON.
                        "tags" : ["prepTag"],
                        
                        "ordering" : {
                            "before" : "makeTag"
                        },

                        # Unused but mandatory fields (see HfPluginRegistry).
                        "priority": 0,
                        "displayName": "Grind Coffee Beans Scene Index Plugin"
                    },
                    "TestHdSip_BoilWater" : {
                        "bases": ["HdSceneIndexPlugin"],
                        "loadWithRenderer" : "",
                        "loadWithApps" : "",

                        # New fields to express scene index plugin ordering
                        # via JSON.
                        "tags" : ["prepTag"],

                        # Intentionally leaving out "ordering" here. Because it
                        # has the tag "prepTag" and below, TestHdSip_PourOver
                        # specifies that it should come after any plugin with
                        # the "prepTag" tag.

                        # Unused but mandatory fields (see HfPluginRegistry).
                        "priority": 0,
                        "displayName": "Boil Water Scene Index Plugin"
                    },
                    "TestHdSip_PourOver" : {
                        "bases": ["HdSceneIndexPlugin"],
                        "loadWithRenderer" : "",
                        "loadWithApps" : "",

                        # New fields to express scene index plugin ordering
                        # via JSON.
                        "tags" : ["makeTag"],
                        "ordering" : {
                            "after" : "prepTag"
                        },

                        # Unused but mandatory fields (see HfPluginRegistry).
                        "priority": 0,
                        "displayName": "Pour Over Scene Index Plugin"
                    },
                    "TestHdSip_DrinkCoffee" : {
                        "bases": ["HdSceneIndexPlugin"],
                        "loadWithRenderer" : "",
                        "loadWithApps" : "",
                        
                        # New fields to express scene index plugin ordering
                        # via JSON.
                        "tags" : ["enjoyTag"],
                        "ordering" : {
                            "after" : "makeTag"
                        },
                        
                        # Unused but mandatory fields (see HfPluginRegistry).
                        "priority": 0,
                        "displayName": "Drink Coffee Scene Index Plugin"
                    }
                }
            }
        }
    ]
}